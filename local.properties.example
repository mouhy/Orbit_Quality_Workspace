# Copy this file to `local.properties` (gitignored) and fill in your values.
# `local.properties` is never committed.

sdk.dir=/path/to/Android/Sdk

# Backend API base (note the trailing slash and /api/v1/)
#   Emulator:        http://10.0.2.2:8000/api/v1/
#   Physical device: http://<YOUR_PC_LAN_IP>:8000/api/v1/
BASE_URL=http://10.0.2.2:8000/api/v1/
WS_BASE_URL=ws://10.0.2.2:8000

# SSL certificate pinning (only enforced over HTTPS).
# Replace PIN_SHA256 with your backend certificate's SHA-256 hash, e.g.:
#   openssl s_client -connect host:443 | openssl x509 -pubkey -noout \
#     | openssl pkey -pubin -outform der | openssl dgst -sha256 -binary | openssl enc -base64
PIN_HOST=10.0.2.2
PIN_SHA256=sha256/AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA=
