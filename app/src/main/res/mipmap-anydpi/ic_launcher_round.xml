<?xml version="1.0" encoding="utf-8"?>
<!-- Legacy round launcher (API < 26) -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Brand circle -->
    <item
        android:width="48dp"
        android:height="48dp"
        android:gravity="center">
        <shape android:shape="oval">
            <solid android:color="@color/ic_launcher_background" />
        </shape>
    </item>

    <!-- Centered logo (aspect-preserved) -->
    <item
        android:width="28dp"
        android:height="20dp"
        android:gravity="center"
        android:drawable="@drawable/orbit_logo_mark" />

</layer-list>
