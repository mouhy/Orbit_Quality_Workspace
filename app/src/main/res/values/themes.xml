<resources>
    <style name="Theme.Orbit" parent="android:Theme.Material.NoActionBar">
        <item name="android:windowBackground">@color/orbit_window_dark</item>
        <item name="android:statusBarColor">@color/orbit_window_dark</item>
        <item name="android:navigationBarColor">@color/orbit_window_dark</item>
    </style>

    <style name="Theme.Orbit.Starting" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/orbit_window_dark</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/splash_logo</item>
        <item name="postSplashScreenTheme">@style/Theme.Orbit</item>
    </style>
</resources>
